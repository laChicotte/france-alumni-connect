# Configuration de l'application
NODE_ENV=production

# Supabase (obligatoire)
NEXT_PUBLIC_SUPABASE_URL=https://votre-projet.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=votre_anon_key
# Clé service role - UNIQUEMENT côté serveur, pour l'API d'inscription (ne jamais exposer au client)
SUPABASE_SERVICE_ROLE_KEY=votre_service_role_key
NEXTAUTH_URL=https://yourdomain.com
NEXTAUTH_SECRET=your-super-secret-key-here

# Base de données (si vous ajoutez une vraie DB plus tard)
DATABASE_URL=postgresql://username:password@localhost:5432/france_alumni_db

# Configuration email Resend (notifications serveur)
# RESEND_API_KEY doit rester uniquement côté serveur, ne jamais utiliser NEXT_PUBLIC.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# En production, remplacez onboarding@resend.dev par une adresse de domaine vérifié dans Resend.
RESEND_FROM="France Alumni Guinée <onboarding@resend.dev>"
EMAIL_ADMIN_TO=france.alumni@institutfrancais-guinee.fr
# yes = tous les emails partent vers EMAIL_ADMIN_TO ; no = vrais destinataires ; false = aucun email.
SEND_MAIL_ADMIN=no

# Configuration upload de fichiers
UPLOAD_MAX_SIZE=5242880
UPLOAD_ALLOWED_TYPES=pdf,jpg,jpeg,png

# Configuration verifDiploma (si intégré)
VERIFDIPLOMA_API_KEY=your-api-key
VERIFDIPLOMA_API_URL=https://api.verifdiploma.com

# Analytics (optionnel)
GOOGLE_ANALYTICS_ID=GA-XXXXXXXXX

# Rate limiting Upstash Redis (obligatoire en production)
# Créer une base gratuite sur https://upstash.com
UPSTASH_REDIS_REST_URL=https://votre-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=votre_token_upstash
